# Runtime Environment (development | production)
ENV=production

# Server Configuration
# Cloud Run sets PORT automatically; this is for local dev
PORT=8080
HOST=0.0.0.0

# Security: CORS Allowed Origins
# Comma-separated list of domains allowed to access this API
ALLOWED_ORIGINS=https://synex.sanelx.com,http://localhost:8080,http://127.0.0.1:8080
